#!/bin/bash
# Lightweight git pre-push hook for Bot Army bots
# Keep push fast/reliable: run quick local validation only.

set -e

MIX_BIN="/Users/abby/.local/share/mise/shims/mix"

REPO_ROOT="$(git rev-parse --show-toplevel)"
export HEX_HOME="$REPO_ROOT/.cache/hex"
export MIX_HOME="$REPO_ROOT/.cache/mix"
mkdir -p "$HEX_HOME" "$MIX_HOME"

echo "🔍 Running pre-push checks..."
echo ""

push_to_main=0
while read -r local_ref local_oid remote_ref remote_oid; do
  if [[ $remote_ref == "refs/heads/main" ]]; then
    push_to_main=1
  fi
done

if [[ $push_to_main -eq 1 ]]; then
  echo "⚠️  Pushing to main branch - running fast validation only..."
  echo ""

  echo "📦 Ensuring Hex + dependencies..."
  "$MIX_BIN" local.hex --force || {
    echo "❌ mix local.hex failed - push aborted"
    exit 1
  }
  "$MIX_BIN" deps.get || {
    echo "❌ mix deps.get failed - push aborted"
    exit 1
  }

  # Compile local path dependencies first so they're available during code compilation
  echo "📦 Compiling path dependencies..."
  for path_dep in ../bot_army_library_*; do
    if [ -d "$path_dep" ]; then
      (cd "$path_dep" && HEX_HOME="$HEX_HOME" MIX_HOME="$MIX_HOME" "$MIX_BIN" deps.compile) || true
    fi
  done
  echo ""

  # Run compile, credo, and tests in parallel for speed
  echo "🔨 Compiling code (incremental)..."
  echo "📝 Running credo..."
  echo "🧪 Running tests..."
  echo ""

  COMPILE_LOG="/tmp/.pre-push-compile-$$.log"
  CREDO_LOG="/tmp/.pre-push-credo-$$.log"
  TEST_LOG="/tmp/.pre-push-test-$$.log"

  # Start all checks in parallel
  "$MIX_BIN" compile >"$COMPILE_LOG" 2>&1 &
  COMPILE_PID=$!

  "$MIX_BIN" credo --strict >"$CREDO_LOG" 2>&1 &
  CREDO_PID=$!

  "$MIX_BIN" test >"$TEST_LOG" 2>&1 &
  TEST_PID=$!

  # Wait for all and collect exit codes
  wait $COMPILE_PID
  COMPILE_EXIT=$?

  wait $CREDO_PID
  CREDO_EXIT=$?

  wait $TEST_PID
  TEST_EXIT=$?

  # Clean up logs on success
  rm -f "$COMPILE_LOG" "$CREDO_LOG" "$TEST_LOG"

  # Check results
  if [ $COMPILE_EXIT -ne 0 ]; then
    echo "❌ Compilation failed - push aborted"
    cat "$COMPILE_LOG" 2>/dev/null | tail -30
    exit 1
  fi

  if [ $CREDO_EXIT -ne 0 ]; then
    echo "❌ Credo checks failed - push aborted"
    cat "$CREDO_LOG" 2>/dev/null | tail -30
    exit 1
  fi

  if [ $TEST_EXIT -ne 0 ]; then
    echo "❌ Tests failed - push aborted"
    cat "$TEST_LOG" 2>/dev/null | tail -30
    exit 1
  fi

  echo ""
  echo "🕵️  Checking for Mix.env() in runtime code..."
  if grep -r "Mix.env()" lib/ --include="*.ex" 2>/dev/null | grep -v "@env Mix.env()" > /dev/null; then
    echo "❌ Mix.env() found in runtime code. Use @env Mix.env() for compile-time access instead."
    exit 1
  fi

  echo ""
  echo "✅ Pre-push checks passed"
  echo "ℹ️  Publish releases explicitly with: make push-and-publish"
else
  echo "ℹ️  Pushing to feature branch - skipping pre-push validation"
fi

echo ""
exit 0
